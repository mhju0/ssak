    "Hold to reel — ease off when the line sings": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "눌러서 릴을 감고 — 줄이 울면 살짝 놓아주세요"
          }
        }
      }
    },
    "It slipped away…": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "놓쳐버렸습니다…"
          }
        }
      }
    },
