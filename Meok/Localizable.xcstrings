    "Gentle procedural sounds for the fishing bite and fight. Everything is synthesized — no audio files.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "낚시 입질과 씨름의 잔잔한 소리. 모두 실시간 합성 — 음원 파일 없음."
          }
        }
      }
    },
    "Hang it in the gallery": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "전시관에 걸기"
